# Copy this file to .env and add your API credentials.
# The app works in Demo Mode without credentials.

# Provider options: amadeus or demo
FLIGHT_PROVIDER=amadeus

# Amadeus for Developers credentials
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# test = sandbox/test endpoint, production = live endpoint if your account has access
AMADEUS_ENV=test
